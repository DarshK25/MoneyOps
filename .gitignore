############################
# Monorepo root ignore file
############################

# Python virtual environments
**/venv/

# Local runtime logs
runtime-logs/

# OS/editor junk
.DS_Store
Thumbs.db

# Local env files (each service also has its own .gitignore)
**/.env
**/.env.local

# Database files
*.db
*.sqlite
*.sqlite3
**/data/*.db

# Logs
*.log.txt
full_git_log.txt
entire_git_history.txt

# Build artifacts
**/target/
**/build/
**/dist/
**/__pycache__/
