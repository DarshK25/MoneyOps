# =============================================================
#  MoneyOps — Project .env Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in the real values (get them from the team lead)
#  3. NEVER commit .env to Git
# =============================================================

# ─────────────────────────────────────────────
#  DATABASE — MongoDB Atlas
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/moneyops?retryWrites=true&w=majority&appName=MoneyOps

# ─────────────────────────────────────────────
#  BACKEND (Spring Boot — port 8000)
# ─────────────────────────────────────────────
BACKEND_PORT=8000
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRATION=86400000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─────────────────────────────────────────────
#  AI GATEWAY (FastAPI — port 8001)
# ─────────────────────────────────────────────
AI_GATEWAY_PORT=8001
APP_NAME=MoneyOps AI Gateway
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_FORMAT=json
GROQ_API_KEY=your_groq_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
JWT_SECRET_KEY=your-secret-key-change-in-production

# ─────────────────────────────────────────────
#  VOICE SERVICE (LiveKit Agent — port 8003)
# ─────────────────────────────────────────────
VOICE_SERVICE_PORT=8003
GROQ_MODEL=groq/compound
AI_GATEWAY_URL=http://localhost:8001
AI_GATEWAY_TIMEOUT=30
VAD_MIN_SPEECH_DURATION=0.3
VAD_MIN_SILENCE_DURATION=0.5
SESSION_TIMEOUT_S=600
MAX_CONVERSATION_HISTORY=10
ASSEMBLYAI_API_KEY=your_assemblyai_key
CARTESIA_API_KEY=your_cartesia_key

# ─────────────────────────────────────────────
#  LIVEKIT (shared by ai-gateway + voice-service)
# ─────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─────────────────────────────────────────────
#  FRONTEND (React/Vite — port 5173)
# ─────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
VITE_AI_GATEWAY_URL=http://localhost:8001
VITE_VOICE_SERVICE_URL=http://localhost:8003
