# Copy to .env and set values. Never commit .env or real passwords.

# ----- MongoDB (Atlas or local) -----
# Atlas free tier: https://www.mongodb.com/cloud/atlas → create M0 cluster → Connect → copy URI
# Add database name in URI, e.g. ...mongodb.net/moneyops?retryWrites=...
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/moneyops?retryWrites=true&w=majority
# Local default (no var): mongodb://localhost:27017/moneyops

# ----- Optional -----
# JWT_SECRET=your-256-bit-secret
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
=======
# Copy to .env and fill in values. Do not commit .env.

# --- Kafka (optional; app runs without Kafka when KAFKA_ENABLED=false) ---
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=notification-group

# For managed Kafka (Confluent Cloud, AWS MSK, etc.) set security protocol and JAAS:
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="YOUR_API_KEY" password="YOUR_API_SECRET";

# --- Auth (if using OAuth) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- JWT (override in production) ---
# JWT_SECRET=your-256-bit-secret
